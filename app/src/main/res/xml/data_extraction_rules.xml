<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="bastion.db"/>
        <exclude domain="database" path="bastion.db-shm"/>
        <exclude domain="database" path="bastion.db-wal"/>
        <exclude domain="sharedpref" path="bastion_secure_prefs.xml"/>
        <exclude domain="sharedpref" path="bastion_audit.xml"/>
        <exclude domain="sharedpref" path="bastion_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="bastion.db"/>
        <exclude domain="database" path="bastion.db-shm"/>
        <exclude domain="database" path="bastion.db-wal"/>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
